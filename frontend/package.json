{
  "name": "ayurtrace-frontend",
  "version": "1.0.0",
  "description": "Frontend React application for AyurTrace - Blockchain-based Ayurvedic herb supply chain traceability",
  "private": true,
  "dependencies": {
    "axios": "^1.12.2",
    "bootstrap": "^5.3.2",
    "chart.js": "^4.5.0",
    "formik": "^2.4.3",
    "framer-motion": "^10.16.1",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "qrcode": "^1.5.3",
    "qrcode-reader": "^1.0.4",
    "react": "^18.2.0",
    "react-bootstrap": "^2.8.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.2.0",
    "react-helmet": "^6.1.0",
    "react-icons": "^4.10.1",
    "react-infinite-scroll-component": "^6.1.0",
    "react-leaflet": "^4.2.1",
    "react-loading-skeleton": "^3.3.1",
    "react-moment": "^1.1.3",
    "react-qr-scanner": "^1.0.0-alpha.11",
    "react-router-dom": "^7.9.1",
    "react-scripts": "5.0.1",
    "react-table": "^7.8.0",
    "react-toastify": "^9.1.3",
    "react-webcam": "^7.1.1",
    "socket.io-client": "^4.8.1",
    "web-vitals": "^3.4.0",
    "yup": "^1.3.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.3",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/leaflet": "^1.9.4",
    "@types/qrcode": "^1.5.2",
    "eslint": "^8.47.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.0.2"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "analyze": "npm run build && npx source-map-explorer 'build/static/js/*.js'"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "no-unused-vars": "warn",
      "no-console": "warn"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "proxy": "http://localhost:3001"
}
