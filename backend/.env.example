# ===========================================
# AyurTrace Backend Environment Configuration
# ===========================================

# Application Environment
# Options: development, production, test
NODE_ENV=development

# Server Configuration
PORT=3001

# Database Configuration
# MongoDB connection string
# Format: mongodb://[username:password@]host[:port]/database[?options]
MONGODB_URI=mongodb://localhost:27017/ayurtrace
MONGODB_TEST_URI=mongodb://localhost:27017/ayurtrace_test

# JWT Authentication
# SECURITY WARNING: Generate a strong random secret for production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-please-super-secret-use-crypto-randomBytes-64
JWT_EXPIRE=7d

# Hyperledger Fabric Blockchain
FABRIC_NETWORK_PATH=../blockchain/network
CHAINCODE_NAME=ayurtrace
CHANNEL_NAME=ayurchannel

# External Services
# GPS API Key for location services (optional)
GPS_API_KEY=your_gps_api_key_here

# QR Code Service URL (optional)
QR_SERVICE_URL=https://api.qrserver.com/v1/create-qr-code/

# Rate Limiting
# Window in minutes for rate limiting
RATE_LIMIT_WINDOW_MIN=15
# Maximum requests per window
RATE_LIMIT_MAX=200

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Logging
# Options: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# File Upload Limits
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# ===========================================
# PRODUCTION DEPLOYMENT NOTES
# ===========================================
# 1. Generate strong JWT_SECRET using crypto.randomBytes
# 2. Use production MongoDB with authentication
# 3. Enable SSL/TLS for MongoDB connection
# 4. Use environment-specific CORS_ORIGIN
# 5. Set NODE_ENV=production
# 6. Review and adjust rate limits for production traffic
# 7. Never commit .env file to version control
# 8. Use secrets management (AWS Secrets Manager, Azure Key Vault, etc.)
# ===========================================

