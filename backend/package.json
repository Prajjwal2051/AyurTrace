{
  "name": "ayurtrace-backend",
  "version": "1.0.0",
  "description": "Backend API for AyurTrace - Blockchain-based Ayurvedic herb supply chain traceability",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --watchAll --detectOpenHandles",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "seed": "node scripts/seed-database.js",
    "build": "npm run lint && npm test",
    "docker:build": "docker build -t ayurtrace-backend .",
    "docker:run": "docker run -p 3001:3001 ayurtrace-backend"
  },
  "keywords": [
    "blockchain",
    "hyperledger-fabric",
    "ayurveda",
    "supply-chain",
    "traceability",
    "nodejs",
    "express"
  ],
  "author": "AyurTrace Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto-js": "^4.1.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "fabric-ca-client": "^2.2.19",
    "fabric-network": "^2.2.19",
    "helmet": "^7.0.0",
    "hpp": "^0.2.3",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "qrcode": "^1.5.3",
    "sharp": "^0.32.5",
    "socket.io": "^4.8.1",
    "uuid": "^9.0.0",
    "winston": "^3.10.0",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@types/jest": "^29.5.4",
    "eslint": "^8.47.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.6.2",
    "mongodb-memory-server": "^8.14.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ]
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
